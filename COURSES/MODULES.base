views:
  - type: cards
    name: HTBA MODULES
    filters:
      and:
        - file.tags.contains("HTB")
        - file.tags.contains("MODULE")
    image: note.image
  - type: cards
    name: THM MODULES
    filters:
      and:
        - file.tags.contains("THM")
        - file.tags.contains("MODULE")
    image: note.image
  - type: cards
    name: THM ROOMS
    filters:
      and:
        - file.tags.contains("THM")
        - file.tags.contains("ROOM")
    image: note.image
